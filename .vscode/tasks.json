{
  "inputs": [
    {
      "description": "Ticket URL (GitHub issue, Jira, Linear, Azure DevOps)",
      "id": "ticketUrl",
      "type": "promptString"
    }
  ],
  "tasks": [
    {
      "command": "go test ./...",
      "group": "test",
      "label": "test: default",
      "options": {
        "cwd": "${workspaceFolder}/."
      },
      "type": "shell"
    },
    {
      "command": "golangci-lint run",
      "group": "build",
      "label": "lint: default",
      "options": {
        "cwd": "${workspaceFolder}/."
      },
      "type": "shell"
    },
    {
      "command": "go build ./...",
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "label": "build: default",
      "options": {
        "cwd": "${workspaceFolder}/."
      },
      "type": "shell"
    }
  ],
  "version": "2.0.0"
}